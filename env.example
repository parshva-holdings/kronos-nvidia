# Copy to .env and fill in. .env is gitignored.

# NGC API key — needed to pull nvcr.io/nvidia/* containers and to authenticate
# against NIM endpoints. Generate at https://ngc.nvidia.com/setup
NGC_API_KEY=

# HuggingFace token — only needed for gated repos. Kronos weights are public
# under NeoQuasar so this is OPTIONAL but recommended to avoid rate limits.
HF_TOKEN=

# Which Kronos model to load by default
# Options: NeoQuasar/Kronos-mini | NeoQuasar/Kronos-small | NeoQuasar/Kronos-base
KRONOS_MODEL=NeoQuasar/Kronos-small
KRONOS_TOKENIZER=NeoQuasar/Kronos-Tokenizer-base

# Device for inference: cuda:0 in NVIDIA container, mps on Apple Silicon, cpu otherwise
KRONOS_DEVICE=cuda:0

# Context length — must match tokenizer (512 for base tokenizer, 2048 for 2k tokenizer)
KRONOS_MAX_CONTEXT=512

# Sampling defaults
KRONOS_TEMPERATURE=1.0
KRONOS_TOP_P=0.9
KRONOS_SAMPLE_COUNT=1

# API server
API_HOST=0.0.0.0
API_PORT=8000

# Webui
WEBUI_PORT=7070
